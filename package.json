{
  "name": "atcoder-title-copy",
  "version": "1.0.0",
  "description": "AtCoderの問題名をAtCoderの問題名を「ABC123A - Five Antennas」のようなフォーマットでコピーします。",
  "main": "index.js",
  "scripts": {
    "prebuild": "npm run clean",
    "build": "rollup --config rollup.config.ts --configPlugin typescript --bundleConfigAsCjs",
    "clean": "rimraf dist",
    "predev": "npm run clean",
    "dev": "rollup --config rollup.config.ts --configPlugin typescript --watch --bundleConfigAsCjs",
    "lint": "eslint '**/*.{js,ts}'",
    "lint:userscripts": "ESLINT_USE_FLAT_CONFIG=false eslint --config .eslintrc.userscripts.js 'dist/**/*.js'",
    "test": "jest --passWithNoTests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fe2O3-Tpa/AtCoder-Title-Copy.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Fe2O3-Tpa/AtCoder-Title-Copy/issues"
  },
  "homepage": "https://github.com/Fe2O3-Tpa/AtCoder-Title-Copy#readme",
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node16": "^16.1.8",
    "@types/glob": "^8.1.0",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-plugin-userscripts": "^0.5.6",
    "glob": "^13.0.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.3",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-watch": "^1.0.5",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "userscript-metadata": "^1.1.0"
  }
}
